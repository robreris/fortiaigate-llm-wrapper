# Copy this file to .env and fill in values for local development.
# Do NOT commit .env — add it to .gitignore.
#
# In Kubernetes, these values come from k8s/secret.yaml instead.
# When running via Docker locally: docker run --env-file .env ...

# --- Required ---
OPENAI_API_KEY=sk-...
MCP_SERVER_URL=https://your-mcp-server/mcp

# --- Optional: MCP auth (omit if the MCP server requires no authentication) ---
# MCP_API_KEY=your-mcp-api-token

# --- Optional: defaults shown ---
# DEFAULT_MODEL=gpt-4o
# MCP_REQUIRE_APPROVAL=never
# LOG_LEVEL=INFO
# PORT=8080
